# Yandex Maps API key (referer-restricted на parktrack.live и localhost)
# Получить: https://developer.tech.yandex.ru/services/3
VITE_YMAP_KEY=your-yandex-maps-v3-key-here

# API-режим: 'mock' (MSW handlers) или 'real' (реальный бэкенд).
# В mock-режиме AuthGuard отключён, логин не нужен.
VITE_API_MODE=mock

# Базовый URL backend API.
# Для локального бэка: http://localhost:8000/api/v1
VITE_API_BASE_URL=https://api.parktrack.live

# OSRM-compatible endpoint used only for road-following route geometry.
VITE_ROUTING_GEOMETRY_BASE_URL=https://router.project-osrm.org
